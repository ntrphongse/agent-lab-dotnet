@using SocOps.Models

<button
    @onclick="OnClick"
    disabled="@Square.IsFreeSpace"
    class="@GetCssClasses()"
    aria-pressed="@Square.IsMarked"
    aria-label="@(Square.IsFreeSpace ? "Free space" : Square.Text)">
    <span class="wrap-break-word hyphens-auto font-bold text-center">@Square.Text</span>
    @if (Square.IsMarked && !Square.IsFreeSpace)
    {
        <span class="absolute top-1 right-1 text-memphis-black text-xl font-black animate-memphis-celebrate">✅</span>
    }
    @if (Square.IsFreeSpace)
    {
        <span class="absolute -top-1 -right-1 text-memphis-yellow text-2xl">★</span>
    }
</button>

@code {
    [Parameter]
    public BingoSquareData Square { get; set; } = null!;

    [Parameter]
    public bool IsWinning { get; set; }

    [Parameter]
    public EventCallback OnClick { get; set; }

    private string GetCssClasses()
    {
        var baseClasses = "btn-memphis-square transition-all duration-300 hover:scale-105";

        if (Square.IsFreeSpace)
        {
            return $"{baseClasses} free bg-memphis-pink text-memphis-white border-memphis-black font-black";
        }
        
        if (Square.IsMarked)
        {
            if (IsWinning)
            {
                return $"{baseClasses} winning animate-memphis-pulse";
            }
            return $"{baseClasses} marked bg-memphis-green border-memphis-black text-memphis-black";
        }
        
        return $"{baseClasses} bg-memphis-white border-memphis-black text-memphis-black hover:bg-memphis-yellow";
    }
}
