<div class="flex flex-col items-center justify-center min-h-full p-6 bg-memphis-gradient-1 relative overflow-hidden">
    <!-- Memphis background decorative elements -->
    <div class="absolute top-8 left-8 w-16 h-16 bg-memphis-yellow border-4 border-memphis-black transform rotate-45 animate-memphis-pulse"></div>
    <div class="absolute top-20 right-12 w-12 h-12 bg-memphis-coral rounded-full border-4 border-memphis-black"></div>
    <div class="absolute bottom-20 left-16 w-20 h-6 bg-memphis-green border-4 border-memphis-black transform -rotate-12"></div>
    <div class="absolute bottom-8 right-8 w-14 h-14 bg-memphis-pink border-4 border-memphis-black"></div>
    <div class="absolute top-32 left-1/3 w-8 h-24 bg-memphis-blue border-4 border-memphis-black transform rotate-12"></div>
    <div class="absolute bottom-32 right-1/4 w-6 h-6 bg-memphis-cyan rounded-full border-2 border-memphis-black animate-memphis-pulse"></div>
    
    <!-- Memphis zigzag lines -->
    <div class="absolute top-0 left-0 w-full h-4 opacity-70" style="background: repeating-linear-gradient(90deg, var(--memphis-hot-pink) 0px, var(--memphis-hot-pink) 16px, var(--memphis-bright-yellow) 16px, var(--memphis-bright-yellow) 32px);"></div>
    <div class="absolute bottom-0 left-0 w-full h-4 opacity-70" style="background: repeating-linear-gradient(90deg, var(--memphis-electric-blue) 0px, var(--memphis-electric-blue) 16px, var(--memphis-lime-green) 16px, var(--memphis-lime-green) 32px);"></div>

    <div class="text-center max-w-md relative z-10">
        <!-- Main title with Memphis styling -->
        <div class="memphis-modal p-6 mb-8">
            <h1 class="text-5xl font-memphis font-black text-memphis-black mb-2 tracking-wider uppercase">SOC OPS</h1>
            <div class="w-full h-3 mb-4" style="background: repeating-linear-gradient(90deg, var(--memphis-hot-pink) 0px, var(--memphis-hot-pink) 8px, var(--memphis-bright-yellow) 8px, var(--memphis-bright-yellow) 16px);"></div>
            <p class="text-2xl font-body font-bold text-memphis-pink mb-4 uppercase tracking-wide">Social Bingo</p>
            <p class="text-lg font-body font-bold text-memphis-black uppercase">Memphis Edition!</p>
        </div>

        <!-- How to play section with Memphis styling -->
        <div class="bg-memphis-white border-4 border-memphis-black p-6 shadow-memphis mb-8 relative">
            <div class="absolute -top-3 -right-3 w-6 h-6 bg-memphis-coral border-2 border-memphis-black transform rotate-45"></div>
            <h2 class="font-memphis font-black text-memphis-black mb-4 text-xl uppercase tracking-wide">How to Play</h2>
            <ul class="text-left text-memphis-black font-body font-bold space-y-3">
                <li class="flex items-center">
                    <span class="w-6 h-6 bg-memphis-pink border-2 border-memphis-black rounded-full mr-3 flex items-center justify-center text-memphis-white font-black text-sm">1</span>
                    Find people who match the questions
                </li>
                <li class="flex items-center">
                    <span class="w-6 h-6 bg-memphis-green border-2 border-memphis-black rounded-full mr-3 flex items-center justify-center text-memphis-black font-black text-sm">2</span>
                    Tap a square when you find a match
                </li>
                <li class="flex items-center">
                    <span class="w-6 h-6 bg-memphis-blue border-2 border-memphis-black rounded-full mr-3 flex items-center justify-center text-memphis-white font-black text-sm">3</span>
                    Get 5 in a row to win!
                </li>
            </ul>
        </div>

        <!-- Start button with Memphis styling -->
        <button
            @onclick="OnStart"
            class="btn-memphis-primary w-full py-4 px-8 text-xl font-black tracking-wider hover-memphis">
            🚀 START JAMMING! 🚀
        </button>
        
        <!-- Decorative Memphis elements -->
        <div class="mt-4 flex justify-center space-x-2">
            <div class="w-4 h-4 bg-memphis-yellow border-2 border-memphis-black transform rotate-45"></div>
            <div class="w-4 h-4 bg-memphis-coral rounded-full border-2 border-memphis-black"></div>
            <div class="w-4 h-4 bg-memphis-green border-2 border-memphis-black"></div>
            <div class="w-4 h-4 bg-memphis-pink border-2 border-memphis-black transform rotate-45"></div>
            <div class="w-4 h-4 bg-memphis-blue rounded-full border-2 border-memphis-black"></div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnStart { get; set; }
}
