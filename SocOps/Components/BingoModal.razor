<div class="fixed inset-0 bg-black/50 flex items-center justify-center p-4 z-50">
    <div class="memphis-modal rounded-none p-8 max-w-sm w-full text-center animate-memphis-celebrate">
        <!-- Memphis geometric decorations -->
        <div class="absolute -top-6 -left-6 w-12 h-12 bg-memphis-yellow border-4 border-memphis-black transform rotate-45 animate-memphis-pulse"></div>
        <div class="absolute -top-4 -right-4 w-8 h-8 bg-memphis-coral rounded-full border-3 border-memphis-black"></div>
        <div class="absolute -bottom-6 -left-4 w-16 h-4 bg-memphis-green border-3 border-memphis-black transform -rotate-12"></div>
        <div class="absolute -bottom-4 -right-6 w-10 h-10 bg-memphis-pink border-3 border-memphis-black"></div>
        
        <!-- Celebration content -->
        <div class="text-6xl mb-4 animate-memphis-celebrate">🎉⚡🎊</div>
        <h2 class="text-4xl font-memphis font-black text-memphis-pink mb-2 tracking-wider">BINGO!</h2>
        <p class="text-lg font-body font-bold text-memphis-black mb-6 uppercase tracking-wide">Memphis Style Winner!</p>
        
        <!-- Zigzag decoration -->
        <div class="w-full h-2 mb-6 opacity-80" style="background: repeating-linear-gradient(90deg, var(--memphis-hot-pink) 0px, var(--memphis-hot-pink) 12px, var(--memphis-bright-yellow) 12px, var(--memphis-bright-yellow) 24px);"></div>

        <button
            @onclick="OnDismiss"
            class="btn-memphis-primary w-full py-4 px-8 text-lg font-black tracking-wide hover-memphis">
            KEEP JAMMING!
        </button>
        
        <!-- Floating shapes animation -->
        <div class="absolute top-4 right-8 w-3 h-3 bg-memphis-cyan border border-memphis-black animate-memphis-pulse" style="animation-delay: 0.5s"></div>
        <div class="absolute top-12 left-8 w-2 h-8 bg-memphis-orange border border-memphis-black animate-memphis-pulse" style="animation-delay: 1s"></div>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnDismiss { get; set; }
}
